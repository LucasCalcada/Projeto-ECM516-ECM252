{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "es2022",
    "target": "es2022",
    "moduleResolution": "node",
    "types": ["node"],

    "strict": true,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,

    "baseUrl": "./",
    "paths": {
      "@app/*": ["src/*"],
      "@db/*": ["src/db/*"],
      "@schema/*": ["src/db/schema/*"],
      "@helpers/*": ["src/helpers/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
